# n8n webhook base URL (no trailing slash). API routes proxy to n8n to avoid CORS.
# Use only ONE of these (do not set the same key twice).
# Local n8n:
# N8N_WEBHOOK_URL=http://localhost:5678/webhook
# n8n cloud (ensure "Worker Orders List" workflow is active):
# N8N_WEBHOOK_URL=https://nhuhoang.app.n8n.cloud/webhook
N8N_WEBHOOK_URL=http://localhost:5678/webhook

# Frontend app URL (no trailing slash). Required for live status updates: when a worker
# updates a procedure status here, the frontend notifies the user's browser via SSE.
# e.g. http://localhost:7030 or https://your-frontend.vercel.app
# FRONTEND_URL=http://localhost:7030