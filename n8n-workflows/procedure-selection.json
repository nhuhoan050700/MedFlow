        }
      }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO order_items (order_id, procedure_id, procedure_name, room_number, amount) VALUES ($1, $2, $3, $4, $5) RETURNING *",
        "additionalFields": {
          "queryParameters": "={{ [$('Create Order').first().json.id, $('Prepare Order Row').first().json.procedure_id, $('Prepare Order Row').first().json.procedure_name, $('Prepare Order Row').first().json.room_number, $('Prepare Order Row').first().json.total_amount] }}"
        }
      },
      "id": "create-order-item",
