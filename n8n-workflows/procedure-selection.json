    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT * FROM procedures WHERE id = ANY($1::integer[])",
        "additionalFields": {
          "queryParameters": "={{ [($json.body && $json.body.procedure_id != null) ? $json.body.procedure_id : $json.procedure_id] }}"
        }
